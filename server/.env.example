# MongoDB Atlas connection string (include the database name in the path)
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/examen-datascience?retryWrites=true&w=majority
MONGODB_URI=

# Long random secret used to sign JWT tokens (students + admin sessions)
JWT_SECRET=

# Admin dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Server port (Render sets this automatically in production)
PORT=5000

# development | production
NODE_ENV=development

# Frontend origin allowed to call the API via CORS.
# Only needed in development (Vite dev server). Leave empty in production
# since the client is served by this same server.
CLIENT_URL=http://localhost:5173
